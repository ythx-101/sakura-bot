# Sakura Bot Configuration
# Copy this file to jav_config.yaml and fill in your values

# Proxy settings (set use_proxy to 1 to enable)
use_proxy: 0
proxy_addr: "http://127.0.0.1:7890"

# Telegram settings
tg_api_id: "YOUR_TG_API_ID"
tg_api_hash: "YOUR_TG_API_HASH"
tg_bot_token: "YOUR_BOT_TOKEN"
tg_chat_id: "YOUR_CHAT_ID"

# NSFW filter (0=allow, 1=block)
enable_nsfw: 1

# PikPak Bot username (for magnet saving)
pikpak_bot_name: "PikPak6_Bot"

# Gemini API Key (for AI features: /clips, /recommend, /imgsearch)
gemini_api_key: "YOUR_GEMINI_API_KEY"

# PikPak mount directories (rclone FUSE mounts)
pikpak_dirs:
  - "/mnt/pikpak-mypack"
  - "/mnt/pikpak-movies"
  - "/mnt/pikpak-series"

# Pyrogram session path (for PikPak bot messaging)
tg_session: "~/.sakura-bot/tg_session"
